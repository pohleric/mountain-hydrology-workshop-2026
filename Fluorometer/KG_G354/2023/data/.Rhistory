# Define the standard normal probability density function (PDF)
standard_normal_pdf <- function(x) {
(1/sqrt(2 * pi)) * exp(-0.5 * x^2)
}
# Define the mean-shifted standard normal PDF
mean_shifted_normal_pdf <- function(x) {
(1/sqrt(2 * pi)) * exp(-0.5 * (x - 1)^2)
}
# Define the range of x values
x_values <- seq(-5, 5, by = 0.1)
# Calculate the PDF values for the standard normal distribution
standard_normal_values <- standard_normal_pdf(x_values)
# Calculate the PDF values for the mean-shifted standard normal distribution
mean_shifted_normal_values <- mean_shifted_normal_pdf(x_values)
# Plot the standard normal distribution
plot(x_values, standard_normal_values, type = "l", col = "blue", xlab = "x", ylab = "Probability Density", main = "Standard Normal Distribution")
# Add the mean-shifted standard normal distribution to the plot
lines(x_values, mean_shifted_normal_values, col = "red")
# Convolve the two distributions
convolution_values <- convolve(standard_normal_values, mean_shifted_normal_values, type = "open")
# Plot the resulting convolution
plot(convolution_values, type = "l", col = "green", xlab = "x", ylab = "Probability Density", main = "Convolution of Distributions")
(1/sqrt(2 * pi)) * exp(-0.5 * (x - 2)^2)
