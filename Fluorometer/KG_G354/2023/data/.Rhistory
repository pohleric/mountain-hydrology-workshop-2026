# Load required library for gamma distribution
library(MASS)
# Define the first gamma distribution with shape parameter alpha1
alpha1 <- 2
beta1 <- 1
gamma_pdf1 <- function(x) {
dgamma(x, shape = alpha1, rate = beta1)
}
# Define the second gamma distribution with shape parameter alpha2
alpha2 <- 3
beta2 <- 1
gamma_pdf2 <- function(x) {
dgamma(x, shape = alpha2, rate = beta2)
}
# Define the range of x values
x_values <- seq(0, 10, by = 0.1)
# Calculate the PDF values for the first gamma distribution
gamma_values1 <- gamma_pdf1(x_values)
# Calculate the PDF values for the second gamma distribution
gamma_values2 <- gamma_pdf2(x_values)
# Plot the first gamma distribution
plot(x_values, gamma_values1, type = "l", col = "blue", xlab = "x", ylab = "Probability Density", main = "Gamma Distributions")
# Add the second gamma distribution to the plot
lines(x_values, gamma_values2, col = "red")
# Convolve the two distributions
convolution_values <- convolve(gamma_values1, gamma_values2, type = "open")
# Plot the resulting convolution
plot(convolution_values, type = "l", col = "green", xlab = "x", ylab = "Probability Density", main = "Convolution of Distributions")
convolution_values
x_values
x_values
convolution_values
convolution_values = convolution_values/ sum(convolution_values)
# Plot the resulting convolution
plot(convolution_values, type = "l", col = "green", xlab = "x", ylab = "Probability Density", main = "Convolution of Distributions")
sum(convolution_values)
# Convolve the two distributions
convolution_values <- convolve(gamma_values1, gamma_values2, type = "open")
sum(convolution_values)
